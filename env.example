# 🔐 متغيرات البيئة لمشروع صحيفة سبق
# انسخ هذا الملف إلى .env وأضف القيم الفعلية

# ===== قاعدة البيانات Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ===== الذكاء الاصطناعي =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-org-id

# ===== المصادقة (اختر واحدة) =====
# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key

# أو Supabase Auth
NEXT_PUBLIC_SUPABASE_AUTH_URL=https://your-project.supabase.co/auth/v1

# ===== URLs =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CDN_URL=https://your-cdn.com

# ===== تخزين الملفات =====
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=me-south-1
S3_BUCKET_NAME=sabq-media

# ===== البريد الإلكتروني =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@sabq.org
SMTP_PASS=your-password

# ===== التحليلات =====
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===== مراقبة الأخطاء =====
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ORG=sabq
SENTRY_PROJECT=sabq-cms

# ===== Redis (للتخزين المؤقت) =====
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# ===== البحث =====
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=your-api-key

# ===== إعدادات التطبيق =====
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key
SESSION_SECRET=your-session-secret

# ===== إعدادات الأداء =====
ENABLE_CACHE=true
CACHE_TTL=3600
MAX_UPLOAD_SIZE=10485760
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ===== وسائل التواصل الاجتماعي =====
TWITTER_API_KEY=your-twitter-key
TWITTER_API_SECRET=your-twitter-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-secret

# ===== إعدادات المطورين =====
DEBUG=false
LOG_LEVEL=info
PRETTY_LOGS=false 