# البيئة العامة
NODE_ENV=development
PORT=3000
API_PORT=4000

# قاعدة البيانات PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sabq_cms
DATABASE_SSL=false

# Redis للتخزين المؤقت
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT للمصادقة
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# OpenAI API للذكاء الاصطناعي
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# تخزين الملفات (S3 أو محلي)
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_S3_BUCKET=sabq-media

# البريد الإلكتروني
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sabq.org

# تحليلات PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Push Notifications
FCM_SERVER_KEY=
FCM_SENDER_ID=

# OAuth (اختياري)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# تكوينات الأمان
CORS_ORIGINS=http://localhost:3000,https://sabq.org
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# تكوينات المحتوى
DEFAULT_LANGUAGE=ar
SUPPORTED_LANGUAGES=ar,en
CONTENT_MODERATION=true
AUTO_PUBLISH=false

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
CDN_URL=

# Webhook URLs
WEBHOOK_NEW_ARTICLE=
WEBHOOK_ARTICLE_PUBLISHED=
WEBHOOK_USER_REGISTERED=
